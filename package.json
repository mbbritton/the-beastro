{
  "name": "the-beastro",
  "version": "1.0.0",
  "description": "The Beastro - A pet-themed fine dining experience web application",
  "main": "app.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "npm run build:css && npm run build:js",
    "build:css": "cssnano style.css dist/style.min.css",
    "build:js": "terser app.js -o dist/app.min.js -c -m && terser data.js -o dist/data.min.js -c -m",
    "lighthouse": "lighthouse http://localhost:8080 --output=html --output-path=./lighthouse-report.html",
    "serve": "python3 -m http.server 8080",
    "dev": "npm run serve"
  },
  "keywords": ["pets", "restaurant", "web-app"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dompurify": "^3.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@sentry/browser": "^7.99.0",
    "cssnano": "^6.0.3",
    "cssnano-cli": "^1.0.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^11.4.0",
    "terser": "^5.27.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "app.js",
      "!dist/**",
      "!node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
